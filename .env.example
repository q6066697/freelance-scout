# Скопируй этот файл в .env и впиши свои значения.
# .env НИКОГДА не коммитится в git (см. .gitignore).

# Ключ Anthropic для команд summary и ask.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Источник данных:
#   hh       — hh.ru, рынок РФ (нужен доступ к рунету)
#   trudvsem — «Работа России», гос-портал РФ (часто открыт там, где hh заблокирован)
#   remotive — международные удалёнки, англоязычные
SOURCE=hh

# Сколько вакансий тянуть на один поисковый запрос.
FETCH_LIMIT=50

# Регион для источника hh (113=Россия, 1=Москва, 2=СПб).
HH_AREA=113
